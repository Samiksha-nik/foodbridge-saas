# MongoDB (use either key; MONGO_URI is supported for backward compatibility)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
# MONGO_URI=mongodb+srv://...

# Server
PORT=5000

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRY=7d

# Optional: Nodemailer (if set, OTP is emailed; otherwise OTP is logged to console)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password

# Optional: CORS allowed origin (e.g. http://localhost:5173)
CLIENT_URL=http://localhost:5173
